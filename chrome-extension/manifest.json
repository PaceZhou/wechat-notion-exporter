{
  "manifest_version": 3,
  "name": "微信文章 URL 收集器",
  "version": "1.3.0",
  "description": "跨设备同步的微信文章收集系统",
  "permissions": ["activeTab", "downloads", "storage", "notifications"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://192.168.*:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "save-direct": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "直接保存当前页面"
    }
  }
}
