{
  "manifest_version": 3,
  "name": "微信文章 URL 收集器",
  "version": "2.0",
  "description": "跨设备同步的微信文章收集系统",
  "permissions": ["activeTab", "downloads", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "保存当前页面"
    }
  }
}
